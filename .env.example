# Este arquivo e so referencia (vai pro git). Os valores REAIS de producao/teste
# devem ser cadastrados nas variaveis de ambiente de cada recurso no Coolify,
# nunca commitados aqui.
#
# Se quiser rodar localmente com `docker compose up` pra testar antes de subir
# no Coolify, copie para .env e preencha (esse .env fica de fora do git).

# ---- Identificacao do ambiente ----
# Usado so pra nomear o volume Docker de forma unica (ex: producao / teste)
N8N_ENV_NAME=producao

# Versao da imagem do n8n. Sugestao: teste uma versao nova no ambiente de
# teste primeiro, e so depois suba o mesmo numero no ambiente de producao.
N8N_VERSION=2.31.4

# Fuso horario usado nos triggers/schedules
GENERIC_TIMEZONE=America/Sao_Paulo

# ---- Seguranca ----
# Gere um valor por ambiente com: openssl rand -base64 32
# Guarde num cofre de senhas. Se perder, as credenciais salvas no n8n
# desse ambiente ficam ilegiveis (nao tem como recuperar).
N8N_ENCRYPTION_KEY=

# ---- Postgres (embutido no proprio compose, um container por ambiente) ----
# Essas variaveis criam o banco/usuario na primeira subida do container
# "postgres" (initdb) e sao as mesmas usadas pelo n8n pra se conectar nele.
# Nao ha host/porta pra configurar: o n8n fala com o servico "postgres" pela
# rede interna do Docker, sem precisar de SSL.
DB_POSTGRESDB_DATABASE=n8n_producao
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=
